Store* loadAllStores(const string& filename, int& storeCount) {
    ifstream file(filename);

    if (!file.is_open()) {
        cout << "File not found.\n";
        storeCount = 0;
        return nullptr;
    }

    file >> storeCount;
    file.ignore();

    if (storeCount <= 0) {
        file.close();
        return nullptr;
    }

    Store* stores = new Store[storeCount];

    for (int i = 0; i < storeCount; i++) {
        stores[i].loadFromFile(file);
    }

    file.close();
    cout << "File written to: urbanease_data.txt\n\n";

    return stores;
}


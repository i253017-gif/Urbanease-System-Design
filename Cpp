    }

    file.close();
    cout << "SUCCESS: " << storeCount << " stores generated.\n";
    cout << "File written to: urbanease_data.txt\n\n";
}

Cluster* performClustering(Store** storeArray, int storeCount, int k) {
    Centroid* centroids = new Centroid[k];

    for (int i = 0; i < k; i++) {
        int idx = rand() % storeCount;
        Coordinates loc = storeArray[idx]->getLocation();
        centroids[i] = Centroid(loc.getLatitude(), loc.getLongitude(), 0, i);
    }

    Cluster* clusters = new Cluster[k];
    for (int i = 0; i < k; i++) {
        clusters[i] = Cluster(i);
    }

    for (int iter = 0; iter < 10; iter++) {
        for (int i = 0; i < k; i++) {
            clusters[i] = Cluster(i);
        }

        for (int i = 0; i < storeCount; i++) {
            double minDist = 1e9;
            int nearest = 0;

            for (int j = 0; j < k; j++) {
                double dist = centroids[j].distanceToStore(*storeArray[i]);
                if (dist < minDist) {
                    minDist = dist;
                    nearest = j;
                }
            }

            clusters[nearest].addStore(storeArray[i]);
        }

        for (int i = 0; i < k; i++) {
            clusters[i].updateCentroid();
            centroids[i] = clusters[i].getCentroid();
        }
    }

    delete[] centroids;
    return clusters;
}


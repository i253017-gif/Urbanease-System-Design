//Analytics
Analytics::Analytics(int s) : size(s), compositeScore(0) {
    data = new double[size];
    for (int i = 0; i < size; i++) {
        data[i] = 0.0;
    }
}

Analytics::Analytics(const Analytics& other) : size(other.size), compositeScore(other.compositeScore) {
    data = new double[size];
    for (int i = 0; i < size; i++) {
        data[i] = other.data[i];
    }
}

Analytics::~Analytics() {
    delete[] data;
}

Analytics& Analytics::operator=(const Analytics& other) {
    if (this != &other) {
        delete[] data;
        size = other.size;
        compositeScore = other.compositeScore;
        data = new double[size];
        for (int i = 0; i < size; i++) {
            data[i] = other.data[i];
        }
    }
    return *this;
}

double Analytics::operator[](int index) const { //kept messing up so needed another with &
    if (index >= 0 && index < size) {
        return data[index];
    }
    return 0;
}

double& Analytics::operator[](int index) {
    return data[index];
}

int Analytics::getSize() const { return size; }

double Analytics::getTotal() const {
    double total = 0.0;
    for (int i = 0; i < size; i++) {
        total += data[i];
    }
    return total;
}

double Analytics::getAverage() const {
    if (size == 0) return 0;
    return getTotal() / size;
}

double Analytics::getGrowthRate() const {
    if (data[0] == 0) return 0;
    return ((data[size - 1] - data[0]) / data[0]) * 100;
}

void Analytics::calculateCompositeScore() {
    double total = getTotal();
    double growth = getGrowthRate();
    compositeScore = (total * 0.7) + (growth * 0.3);
}

double Analytics::getCompositeScore() const { return compositeScore; }

bool Analytics::operator<(const Analytics& other) const {
    return compositeScore < other.compositeScore;
}

bool Analytics::operator>(const Analytics& other) const {
    return compositeScore > other.compositeScore;
}

Analytics Analytics::operator+(const Analytics& other) const {
    Analytics result(size);
    for (int i = 0; i < size; i++) {
        result.data[i] = data[i] + other.data[i];
    }
    result.calculateCompositeScore();
    return result;
}

//Forecast
Forecast::Forecast() : predictedSales(0), confidenceLevel(0), warningFlag(false), monthsAhead(1) {}
Forecast::~Forecast() {}

void Forecast::generateForecast(const Analytics& sales) {
    double recentAvg = 0;
    for (int i = 18; i < 24; i++) {
        recentAvg += sales[i];
    }
    recentAvg /= 6.0;

    double oldAvg = 0;
    for (int i = 12; i < 18; i++) {
        oldAvg += sales[i];
    }
    oldAvg /= 6.0;

    if (oldAvg == 0) oldAvg = 1;
    double trend = (recentAvg - oldAvg) / oldAvg;
    predictedSales = recentAvg * (1 + trend * 0.5);

    double variance = 0;
    for (int i = 18; i < 24; i++) {
        variance += (sales[i] - recentAvg) * (sales[i] - recentAvg);
    }
    variance /= 6.0;
    double stdDev = sqrt(variance);

    if (recentAvg == 0) {
        confidenceLevel = 0;
    }
    else {
        confidenceLevel = max(0.0, 100.0 - (stdDev / recentAvg * 100.0));
    }
    warningFlag = (trend < -0.05);
}

double Forecast::getPredictedSales() const { return predictedSales; }
double Forecast::getConfidenceLevel() const { return confidenceLevel; }
bool Forecast::hasWarning() const { return warningFlag; }
int Forecast::getMonthsAhead() const { return monthsAhead; }

Forecast Forecast::operator+(const Forecast& other) const {
    Forecast result;
    result.predictedSales = predictedSales + other.predictedSales;
    result.confidenceLevel = (confidenceLevel + other.confidenceLevel) / 2.0;
    result.warningFlag = warningFlag || other.warningFlag;
    return result;
}

Forecast& Forecast::operator++() {
    monthsAhead++;
    predictedSales *= 1.02;
    return *this;
}

Forecast Forecast::operator++(int) {
    Forecast temp = *this;
    monthsAhead++;
    predictedSales *= 1.02;
    return temp;
}


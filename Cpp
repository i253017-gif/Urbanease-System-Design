    if (month >= 0 && month < 24) customers[month] = val;
}

void Store::generateRandomData() {
    for (int i = 0; i < 24; i++) {
        double baseSales = generateRandomDouble(50000, 200000);
        double seasonality = 1.0 + 0.3 * sin((i * 3.14159) / 6.0);
        double s = baseSales * seasonality;

        sales[i] = s;
        costs[i] = s * generateRandomDouble(0.6, 0.7);
        customers[i] = generateRandomInt(500, 2000);
    }

    sales.calculateCompositeScore();
    updateForecast();
}

void Store::updateForecast() {
    forecast.generateForecast(sales);
}

double Store::CalculateProfit() const {
    return sales.getTotal() - costs.getTotal();
}

void Store::saveToFile(ofstream& file) const {
    file << storeName << "|" << storeID << "|"
        << location.getLongitude() << "|" << location.getLatitude() << "\n";

    for (int i = 0; i < 24; i++) {
        file << sales[i] << " ";
    }
    file << "\n";
}

void Store::loadFromFile(ifstream& file) {
    string line;
    getline(file, line);

    size_t pos = 0;
    pos = line.find('|');
    storeName = line.substr(0, pos);
    line.erase(0, pos + 1);

    pos = line.find('|');
    storeID = stoi(line.substr(0, pos));
    line.erase(0, pos + 1);

    double lon, lat;
    pos = line.find('|');
    lon = stod(line.substr(0, pos));
    line.erase(0, pos + 1);
    lat = stod(line);

    location = Coordinates(lon, lat);

    getline(file, line);
    istringstream iss(line);
    double val;
    for (int i = 0; i < 24; i++) {
        iss >> val;
        sales[i] = val;
    }

    sales.calculateCompositeScore();
}


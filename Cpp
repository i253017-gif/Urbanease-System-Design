Store::Store(Coordinates loc, string name, int id, int count)
    : location(loc), storeName(name), storeID(id), staffCount(count),
    sales(24), costs(24), customers(24) {
    if (count > 0) {
        staff = new Employee[count];
    }
    else {
        staff = nullptr;
    }
}

Store::Store(const Store& other)
    : location(other.location), storeName(other.storeName), storeID(other.storeID),
    staffCount(other.staffCount), sales(other.sales), costs(other.costs),
    customers(other.customers), forecast(other.forecast), manager(other.manager) {
    if (staffCount > 0) {
        staff = new Employee[staffCount];
        for (int i = 0; i < staffCount; i++) {
            staff[i] = other.staff[i];
        }
    }
    else {
        staff = nullptr;
    }
}

Store::~Store() {
    if (staff != nullptr) {
        delete[] staff;
        staff = nullptr;
    }
}

Store& Store::operator=(const Store& other) {
    if (this != &other) {
        if (staff != nullptr) {
            delete[] staff;
            staff = nullptr;
        }

        location = other.location;
        storeName = other.storeName;
        storeID = other.storeID;
        staffCount = other.staffCount;
        sales = other.sales;
        costs = other.costs;
        customers = other.customers;
        forecast = other.forecast;
        manager = other.manager;

        if (staffCount > 0) {
            staff = new Employee[staffCount];
            for (int i = 0; i < staffCount; i++) {
                staff[i] = other.staff[i];
            }
        }
        else {
            staff = nullptr;
        }
    }
    return *this;
}

bool Store::operator==(const Store& other) const {
    return storeID == other.storeID;
}


void Store::addEmployee(Employee e) {
    if (staffCount == 0) {
        staff = new Employee[1];
        staff[0] = e;
        staffCount = 1;
    }
    else {
        Employee* newStaff = new Employee[staffCount + 1];
        for (int i = 0; i < staffCount; i++) {

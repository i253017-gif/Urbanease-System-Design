Centroid::Centroid(double lat, double lon, double score, int id)
    : latitude(lat), longitude(lon), performanceScore(score), clusterID(id) {
}

Centroid::~Centroid() {}

double Centroid::getLatitude() const { return latitude; }
double Centroid::getLongitude() const { return longitude; }
double Centroid::getScore() const { return performanceScore; }
int Centroid::getClusterID() const { return clusterID; }

void Centroid::setFeatures(double lat, double lon, double score) {
    latitude = lat;
    longitude = lon;
    performanceScore = score;
}

double Centroid::distanceToStore(const Store& store) const {
    Coordinates loc = store.getLocation();
    double dLat = latitude - loc.getLatitude();
    double dLon = longitude - loc.getLongitude();
    return sqrt(dLat * dLat + dLon * dLon);
}

bool Centroid::operator==(const Centroid& other) const {
    return abs(latitude - other.latitude) < 0.01 &&
        abs(longitude - other.longitude) < 0.01;
}

//CLUSTERSSSSSSSSS
Cluster::Cluster(int id)
    : storeCount(0), capacity(100), clusterID(id), centroid(0, 0, 0, id) {
    stores = new Store * [capacity];
}

Cluster::Cluster(const Cluster& other)
    : storeCount(other.storeCount), capacity(other.capacity), clusterID(other.clusterID), centroid(other.centroid) {
    stores = new Store * [capacity];
    for (int i = 0; i < storeCount; i++) {
        stores[i] = other.stores[i];
    }
}

Cluster::~Cluster() {
    if (stores != nullptr) {
        delete[] stores;
        stores = nullptr;
    }
}

Cluster& Cluster::operator=(const Cluster& other) {
    if (this != &other) {
        if (stores != nullptr) {
            delete[] stores;
        }
        storeCount = other.storeCount;
        capacity = other.capacity;
        clusterID = other.clusterID;
        centroid = other.centroid;

        stores = new Store * [capacity];
        for (int i = 0; i < storeCount; i++) {
            stores[i] = other.stores[i];
        }
    }
    return *this;
}

void Cluster::addStore(Store* store) {
    if (storeCount >= capacity) {
        capacity *= 2;
        Store** newArray = new Store * [capacity];
        for (int i = 0; i < storeCount; i++) {
            newArray[i] = stores[i];
        }
        delete[] stores;
        stores = newArray;
    }
    stores[storeCount++] = store;
}

Store* Cluster::getStore(int index) const {
    if (index >= 0 && index < storeCount) return stores[index];
    return nullptr;
}

int Cluster::getStoreCount() const { return storeCount; }
int Cluster::getClusterID() const { return clusterID; }
Centroid Cluster::getCentroid() const { return centroid; }

void Cluster::updateCentroid() {
    if (storeCount == 0) return;

    double avgLat = 0, avgLon = 0, avgScore = 0;
    for (int i = 0; i < storeCount; i++) {
        Coordinates loc = stores[i]->getLocation();
        avgLat += loc.getLatitude();
        avgLon += loc.getLongitude();
        avgScore += stores[i]->getSales().getCompositeScore();
    }

    avgLat /= storeCount;
    avgLon /= storeCount;
    avgScore /= storeCount;

    centroid.setFeatures(avgLat, avgLon, avgScore);
}

double Cluster::getTotalRevenue() const {
    double total = 0;
    for (int i = 0; i < storeCount; i++) {
        total += stores[i]->getSales().getTotal();
    }
    return total;
}

double Cluster::getTotalProfit() const {
    double total = 0;
    for (int i = 0; i < storeCount; i++) {
        total += stores[i]->CalculateProfit();
    }
    return total;
}

Cluster Cluster::operator+(const Cluster& other) {
    Cluster merged(clusterID);
    for (int i = 0; i < storeCount; i++) {
        merged.addStore(stores[i]);
    }
    for (int i = 0; i < other.storeCount; i++) {
        merged.addStore(other.stores[i]);
    }
    merged.updateCentroid();
    return merged;
}


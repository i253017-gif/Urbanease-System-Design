//Report
Report::Report() : topCount(0), bottomCount(0) {
    topStores = new Store * [10];
    bottomStores = new Store * [5];
}

Report::~Report() {
    if (topStores != nullptr) delete[] topStores;
    if (bottomStores != nullptr) delete[] bottomStores;
}

void Report::generateReport(Store** storeArray, int storeCount) {
    Store** sorted = new Store * [storeCount];
    for (int i = 0; i < storeCount; i++) {
        sorted[i] = storeArray[i];
    }

    for (int i = 0; i < storeCount - 1; i++) {
        for (int j = 0; j < storeCount - i - 1; j++) {
            if (sorted[j]->getSales() < sorted[j + 1]->getSales()) {
                Store* temp = sorted[j];
                sorted[j] = sorted[j + 1];
                sorted[j + 1] = temp;
            }
        }
    }

    topCount = (storeCount < 10) ? storeCount : 10;
    for (int i = 0; i < topCount; i++) {
        topStores[i] = sorted[i];
    }

    bottomCount = (storeCount < 5) ? storeCount : 5;
    for (int i = 0; i < bottomCount; i++) {
        bottomStores[i] = sorted[storeCount - 1 - i];
    }

    delete[] sorted;
}

Store* Report::getTopStore(int index) const {
    if (index >= 0 && index < topCount) return topStores[index];
    return nullptr;
}

Store* Report::getBottomStore(int index) const {
    if (index >= 0 && index < bottomCount) return bottomStores[index];
    return nullptr;
}

int Report::getTopCount() const { return topCount; }
int Report::getBottomCount() const { return bottomCount; }

ostream& operator<<(ostream& os, const Report& r) {
    os << "\n=== TOP 10 ===\n";
    for (int i = 0; i < r.topCount; i++) {
        os << (i + 1) << ". " << r.topStores[i]->getStoreName() << "\n";
    }

    os << "\n=== BOTTOM 5 ===\n";
    for (int i = 0; i < r.bottomCount; i++) {
        os << (i + 1) << ". " << r.bottomStores[i]->getStoreName() << "\n";
    }
    return os;
}

